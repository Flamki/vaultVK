# Public DNS record that points to your Oracle VM public IP.
DOMAIN=api.example.com

# ACME email used by Caddy for Let's Encrypt certificate operations.
ACME_EMAIL=you@example.com

# 64-char hex encryption key for WAL/SSTable.
VAULTKV_KEY_HEX=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Restrict CORS to your deployed Vercel frontend domain.
VAULTKV_CORS_ORIGINS=https://your-frontend.vercel.app
